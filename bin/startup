#!/usr/bin/env python
import os
import signal
import subprocess
from pathlib import Path

import mytools as t
from mytools import log

CONFIG_FILEPATH = t.HOME / (".config/systemd/user/startup.service")
BUN_BINPATH = t.HOME / ".bun/bin"


class SubProcessManager:
    process: list[subprocess.Popen[bytes]] = []

    def cleanup(self, s=None, f=None):
        log.info("cleanup")
        for p in self.process:
            p.terminate()

    def run(self):
        _ = signal.signal(signal.SIGINT, self.cleanup)
        _ = signal.signal(signal.SIGTERM, self.cleanup)

        for p in self.process:
            _ = p.wait()


def bun_server(port: int, cwd: Path):
    if not BUN_BINPATH.exists():
        log.error(f"not found: {BUN_BINPATH}")
        return
    log.info(f"{port} on {cwd}")

    t.cmd(f"fuser -k {port}/tcp || true")
    return subprocess.Popen(
        ("bun", "start:server"),
        cwd=cwd,
        env={
            "PATH": os.environ["PATH"] + os.pathsep + str(BUN_BINPATH),
            "PORT": str(port),
            "NODE_ENV": "production",
            "HTTP_PROXY": "http://127.0.0.1:10808",
        },
        process_group=0,
    )


@t.cli("startup script")
class opts:
    create: bool = t.arg("-c", help="create systemd config")
    delete: bool = t.arg("-d", help="delete systemd config")


def main():
    if getattr(opts, "edit"):
        return
    if opts.delete:
        log.info(f"delete {CONFIG_FILEPATH}")
        CONFIG_FILEPATH.unlink(missing_ok=True)
        return
    if opts.create:
        CONFIG_FILEPATH.parent.mkdir(parents=True, exist_ok=True)
        content = f"""[Unit]
Description=My Startup Script

[Service]
ExecStart={__file__}

[Install]
WantedBy=default.target
"""
        if not CONFIG_FILEPATH.exists() or CONFIG_FILEPATH.read_text() != content:
            log.info(f"create {CONFIG_FILEPATH}")
            _ = CONFIG_FILEPATH.write_text(content)
            t.cmd("""systemctl --user daemon-reload
systemctl --user enable startup
systemctl --user start startup""")
        return

    pm = SubProcessManager()
    for p in (
        bun_server(4050, t.HOME / "proj/crawl"),
        bun_server(2233, t.HOME / "proj/hippocampus"),
    ):
        if p is not None:
            pm.process.append(p)
    pm.run()


main()
